# Paper Trader Configuration
# Copy to .env and fill in your values

# Required: Anthropic API key
PT_ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override defaults
# PT_INITIAL_CASH_CHF=800.0
# PT_CURRENCY=CHF
# PT_HOST=0.0.0.0
# PT_PORT=8420
# PT_DB_PATH=data/paper_trader.db
# PT_TIMEZONE=US/Eastern

# Risk limits
# PT_SAFETY_STOP_PCT=0.50
# PT_MAX_POSITION_PCT=0.30
# PT_MIN_CASH_RESERVE=100.0

# API budget (USD)
# PT_BUDGET_WARN_USD=45.0
# PT_BUDGET_HARD_STOP_USD=50.0

# Movement threshold for midday smart-skip (%)
# PT_MOVEMENT_THRESHOLD_PCT=2.0
